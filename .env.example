# Copy to .env.local for local development. Values below are placeholders.

# Public site origin, no trailing slash. Used for metadataBase, sitemap.xml,
# and robots.txt absolute URLs. Set to the real production domain in Vercel.
NEXT_PUBLIC_SITE_URL=https://hexarylabs.com

# Resend API key used by the /contact form's Server Action to send inquiry
# emails. Get one at https://resend.com/api-keys. Without it, form submissions
# fail with a friendly error telling the visitor to email us directly.
RESEND_API_KEY=

# Sender for contact-form emails. Must be on a domain verified in Resend
# (https://resend.com/domains) — the sandbox address below only delivers to
# the Resend account owner, so replace it before launch.
CONTACT_FROM_EMAIL=Hexary Labs <onboarding@resend.dev>

# Inbox that receives contact-form submissions. Falls back to site.email
# (src/content/site.ts) if unset.
CONTACT_TO_EMAIL=
